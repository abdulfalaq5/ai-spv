# =============================================================================
# SERVER AI MONITORING - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# OpenAI Compatible Endpoint (SumoPod / LiteLLM Endpoint)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=your-sumopod-api-key-here
OPENAI_BASE_URL=https://ai.sumopod.com/v1
OPENAI_MODEL=gpt-4o  # Ubah sesuai model yang tersedia di SumoPod

# -----------------------------------------------------------------------------
# MCP Monitoring Server
# -----------------------------------------------------------------------------
MCP_SERVER_PORT=9003
MCP_LOG_LEVEL=info
NODE_ENV=production
MCP_MONITORING_URL=http://mcp-monitoring:9003/mcp

# -----------------------------------------------------------------------------
# PostgreSQL Monitoring (READ-ONLY credentials)
# -----------------------------------------------------------------------------
# These are the connection details of the PostgreSQL instance to monitor.
# Use a dedicated read-only monitoring user!
POSTGRES_MONITOR_HOST=localhost
POSTGRES_MONITOR_PORT=5432
POSTGRES_MONITOR_DB=postgres
POSTGRES_MONITOR_USER=monitor_ro
POSTGRES_MONITOR_PASSWORD=your-readonly-password-here

# -----------------------------------------------------------------------------
# RabbitMQ Monitoring
# -----------------------------------------------------------------------------
# RabbitMQ Management API (read-only user)
RABBITMQ_MONITOR_HOST=localhost
RABBITMQ_MONITOR_PORT=15672
RABBITMQ_MONITOR_USER=monitor_ro
RABBITMQ_MONITOR_PASSWORD=your-readonly-password-here

# -----------------------------------------------------------------------------
# Cloudflare API (READ-ONLY token)
# -----------------------------------------------------------------------------
# Create a token at: https://dash.cloudflare.com/profile/api-tokens
# Permissions needed: Zone:Read, Analytics:Read
CLOUDFLARE_API_TOKEN=your-cloudflare-readonly-token-here
CLOUDFLARE_ZONE_ID=your-zone-id-here

# -----------------------------------------------------------------------------
# OpenClaw
# -----------------------------------------------------------------------------
OPENCLAW_PORT=9001

# -----------------------------------------------------------------------------
# Security & Privileges
# -----------------------------------------------------------------------------
# Comma-separated list of whitelisted emails allowed to use the monitoring tools
EMAIL_WHITELIST_MONITORING=falaq@example.com,user@example.com

# Comma-separated list of whitelisted emails allowed to use the HR tools
EMAIL_WHITELIST_HR=falaq@example.com,hr@example.com

# Set to true to allow write and update operations, false to deny them
IS_CREATED_UPDATE=false

# -----------------------------------------------------------------------------
# Telegram Integration (OpenClaw)
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=your-openclaw-telegram-bot-token-here

# -----------------------------------------------------------------------------
# Telegram Public Chat Bot (ai-spv direct integration)
# Gunakan bot BARU yang terpisah dari bot OpenClaw di atas!
# Buat via @BotFather: /newbot
# TELEGRAM_WEBHOOK_SECRET: buat random string panjang untuk validasi webhook
# Contoh generate: openssl rand -hex 32
# -----------------------------------------------------------------------------
TELEGRAM_PUBLIC_BOT_TOKEN=your-public-bot-token-here
TELEGRAM_WEBHOOK_SECRET=your-random-secret-string-here

# -----------------------------------------------------------------------------
# Discord Integration
# -----------------------------------------------------------------------------
DISCORD_ENABLED=true
DISCORD_BOT_TOKEN=your-discord-bot-token-here
DISCORD_ALERT_CHANNEL_ID=1381234567890123456
DISCORD_ALLOWED_USERS=123456789012345678,234567890123456789

# -----------------------------------------------------------------------------
# Notification Distribution (ai-spv -> OpenClaw)
# -----------------------------------------------------------------------------
OPENCLAW_URL=http://openclaw:9001
OPENCLAW_GATEWAY_TOKEN=your_gateway_token_here
OPENCLAW_NOTIFY_CHANNEL=telegram
# e.g., @username or chat_id for telegram
OPENCLAW_NOTIFY_TARGET=your_telegram_target_here

# -----------------------------------------------------------------------------
# WeCom Intelligent AI Bot Integration
# -----------------------------------------------------------------------------
# Set WECOM_ENABLED=true untuk mengaktifkan integrasi WeCom
# Dapatkan credentials di: https://work.weixin.qq.com/wework_admin/frame#apps
#
# WECOM_BOT_ID  : Bot ID dari halaman WeCom Intelligent AI Bot
# WECOM_SECRET  : Secret dari halaman yang sama
# AI_SERVER_URL : URL ke mcp-monitoring service untuk fetch metrics snapshot
# -----------------------------------------------------------------------------
WECOM_ENABLED=false
WECOM_BOT_ID=your-wecom-bot-id-here
WECOM_SECRET=your-wecom-bot-secret-here
AI_SERVER_URL=http://mcp-monitoring:9003