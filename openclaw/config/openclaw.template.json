{
  "agents": {
    "defaults": {
      "workspace": "/home/node/.openclaw/workspace"
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "botToken": "${TELEGRAM_BOT_TOKEN}",
      "dmPolicy": "pairing"
    },
    "discord": {
      "enabled": "__DISCORD_ENABLED__",
      "token": "${DISCORD_BOT_TOKEN}",
      "dmPolicy": "allowlist",
      "allowFrom": [
        "${DISCORD_ALLOWED_USER_1}",
        "${DISCORD_ALLOWED_USER_2}",
        "${DISCORD_ALLOWED_USER_3}",
        "${DISCORD_ALLOWED_USER_4}",
        "${DISCORD_ALLOWED_USER_5}"
      ]
    }
  },
  "gateway": {
    "mode": "local",
    "auth": {
      "mode": "none"
    },
    "port": 9001,
    "bind": "lan",
    "controlUi": {
      "allowedOrigins": [
        "https://smart.motorsights.com",
        "http://smart.motorsights.com"
      ]
    },
    "tailscale": {
      "mode": "off",
      "resetOnExit": false
    },
    "http": {
      "endpoints": {
        "chatCompletions": {
          "enabled": true
        }
      }
    }
  },

  "models": {
    "providers": {
      "ai-spv": {
        "api": "openai-completions",
        "baseUrl": "http://ai-spv:9002/v1",
        "apiKey": "spv-internal",
        "models": [
          {
            "id": "ai-spv",
            "name": "AI-SPV Router"
          }
        ]
      }
    }
  },
  "mcp": {
    "servers": {
      "server-monitoring": {
        "transport": "streamable-http",
        "url": "${MCP_MONITORING_URL}",
        "enabled": false
      }
    }
  },
  "session": {
    "dmScope": "per-channel-peer"
  },
  "tools": {
    "profile": "coding",
    "deny": [
      "${OPENCLAW_DENIED_TOOL_1}",
      "${OPENCLAW_DENIED_TOOL_2}",
      "${OPENCLAW_DENIED_TOOL_3}",
      "${OPENCLAW_DENIED_TOOL_4}",
      "${OPENCLAW_DENIED_TOOL_5}",
      "${OPENCLAW_DENIED_TOOL_6}"
    ]
  },
  "skills": {
    "install": {
      "nodeManager": "npm"
    }
  },
  "meta": {
    "lastTouchedVersion": "2026.6.1",
    "lastTouchedAt": "2026-06-04T07:25:39.830Z"
  }
}