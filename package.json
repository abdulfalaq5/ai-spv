{
  "name": "ai-spv",
  "version": "1.0.0",
  "description": "AI Supervisor, Router, Orchestrator, Aggregator",
  "main": "dist/app.js",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "migrate:make": "knex --knexfile src/database/knex.ts migrate:make -x ts",
    "migrate:latest": "knex --knexfile dist/database/knex.js migrate:latest",
    "migrate:rollback": "knex --knexfile dist/database/knex.js migrate:rollback",
    "seed:run": "knex --knexfile dist/database/knex.js seed:run"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "knex": "^3.1.0",
    "openai": "^4.40.0",
    "pg": "^8.11.5",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.5",
    "tsup": "^8.0.2",
    "tsx": "^4.9.0",
    "typescript": "^5.4.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
